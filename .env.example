# URL of the PrizeFlow backend (Render/Railway), no trailing slash
VITE_API_BASE_URL=https://your-backend.onrender.com

# Optional: enables the "Continue with Google" button on the guest form
# (just a convenience prefill, never required to play). To get a Client ID:
# 1. https://console.cloud.google.com/apis/credentials
# 2. Create Credentials -> OAuth client ID -> Web application
# 3. Authorized JavaScript origins: add your Netlify URL (and http://localhost:5173 for local dev)
# 4. Copy the Client ID below. Leave empty to hide the button entirely.
VITE_GOOGLE_CLIENT_ID=
